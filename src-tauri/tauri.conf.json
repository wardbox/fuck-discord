{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Relay",
  "version": "0.1.0",
  "identifier": "chat.relay.desktop",
  "build": {
    "beforeDevCommand": "cd client && npm run dev",
    "beforeBuildCommand": "cd client && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../client/build"
  },
  "app": {
    "windows": [
      {
        "title": "Relay",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https: wss: http: ws:; img-src 'self' https: data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {}
}
